NODE_ENV=development
PORT=4001

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fax_crm
DB_CONNECTION_LIMIT=10

FRONTEND_ORIGIN=http://localhost:3001

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# callcenter-ai-system 連携
# REST API（既存の callcenterClient.js が使用、JWT 認証）
CALLCENTER_API_BASE_URL=https://callcenter-backend-production.up.railway.app
CALLCENTER_API_TOKEN=                       # サービスアカウントの JWT (isServiceAccount=true 推奨)
# Webhook push 用シークレット（contact_event 作成時に callcenter にリアルタイム通知）
# callcenter 側の FAX_CRM_WEBHOOK_SECRET と完全一致させること
CALLCENTER_WEBHOOK_SECRET=change_this_to_a_long_random_string
